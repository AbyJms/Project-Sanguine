{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/frontend/login.html"
    },
    {
      "src": "^/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}